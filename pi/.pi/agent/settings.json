{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "mediumProvider": "openai-codex",
  "mediumModel": "gpt-5.3-codex-spark",
  "smallProvider": "openai-codex",
  "smallModel": "gpt-5.4-mini",
  "theme": "catppuccin-macchiato",
  "editorPaddingX": 1,
  "defaultThinkingLevel": "xhigh",
  "terminal": {
    "showImages": true,
    "clearOnShrink": false
  },
  "showHardwareCursor": true,
  "doubleEscapeAction": "tree",
  "compaction": {
    "enabled": true,
    "reserveTokens": 9000,
    "keepRecentTokens": 55000
  },
  "packages": [
    "https://github.com/carderne/pi-nvim",
    "npm:checkpoint-pi",
    "npm:@tmustier/pi-ralph-wiggum",
    "git:github.com/addyosmani/agent-skills@0.5.0",
    "npm:pi-model-aware-compaction"
  ],
  "hideThinkingBlock": false,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.3-codex-spark"
  ]
}